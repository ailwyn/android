<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="net.burgess1.meal_ideas"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="15"
        android:targetSdkVersion="17" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/AppTheme" >
        <activity
            android:name="net.burgess1.meal_ideas.MealsActivity"
            android:label="@string/title_activity_meals" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="net.burgess1.meal_ideas.NewMealActivity"
            android:label="@string/title_activity_new_meal"
            android:parentActivityName="net.burgess1.meal_ideas.MealsActivity" >
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="net.burgess1.meal_ideas.MealsActivity" />
        </activity>
    </application>

</manifest>